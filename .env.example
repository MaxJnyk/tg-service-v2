# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=tg-service-v2
KAFKA_TOPICS=["scrape_platform","send_bot_message","edit_bot_message","delete_bot_message"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@tg-service-db:5432/tg_service

# Redis
REDIS_URL=redis://tg-service-redis:6379/0

# Security — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_KEY_HERE

# Telegram pools
BOT_POOL_MAX_SIZE=50
SESSION_POOL_MAX_SIZE=20

# Consumer concurrency (max parallel Kafka message handlers)
CONSUMER_CONCURRENCY=10

# Monitoring
LOG_LEVEL=INFO
METRICS_PORT=9090

# Sentry (leave empty to disable)
SENTRY_DSN=

# Graceful shutdown
SHUTDOWN_TIMEOUT=30
