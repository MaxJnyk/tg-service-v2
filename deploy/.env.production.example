# ============================================================
# Production Environment Variables
# tg-service-v2 Production Deployment
# ============================================================

# -----------------------------------------------------------
# Traefik / Reverse Proxy
# -----------------------------------------------------------
TRAEFIK_DOMAIN_METRICS=tg-metrics.lgd.cx

# -----------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------
POSTGRES_USER=tg_service_prod
POSTGRES_PASSWORD=<generate_strong_password_32_chars>
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@tg-service-db:5432/tg_service

# -----------------------------------------------------------
# Redis
# -----------------------------------------------------------
REDIS_PASSWORD=<generate_strong_password_32_chars>
REDIS_URL=redis://:${REDIS_PASSWORD}@tg-service-redis:6379/0

# -----------------------------------------------------------
# Kafka
# -----------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka.tad.internal:9092
KAFKA_GROUP_ID=tg-service-v2-prod
KAFKA_TOPICS=["scrape_platform","send_bot_message","edit_bot_message","delete_bot_message"]

# -----------------------------------------------------------
# Security (Fernet Encryption Key)
# -----------------------------------------------------------
ENCRYPTION_KEY=<32_byte_base64_key>

# -----------------------------------------------------------
# Telegram Pool Settings
# -----------------------------------------------------------
BOT_POOL_MAX_SIZE=100
SESSION_POOL_MAX_SIZE=50
MAX_CONCURRENT_SCRAPING=20

# -----------------------------------------------------------
# Consumer Concurrency
# -----------------------------------------------------------
CONSUMER_CONCURRENCY=20

# -----------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------
LOG_LEVEL=WARNING
METRICS_PORT=9090

# -----------------------------------------------------------
# Sentry
# -----------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------
SHUTDOWN_TIMEOUT=60
