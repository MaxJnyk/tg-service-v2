# Kafka — общий kafka из dev-storages (container name: common-kafka)
KAFKA_BOOTSTRAP_SERVERS=common-kafka:9092
KAFKA_GROUP_ID=tg-service-v2
KAFKA_TOPICS=["scrape_platform","send_bot_message","edit_bot_message","delete_bot_message"]

# Database — свой postgres контейнер tg-service-db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@tg-service-db:5432/tg_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis — свой redis контейнер tg-service-redis
REDIS_URL=redis://tg-service-redis:6379/0

# Security — сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_REAL_FERNET_KEY

# Telegram pools
BOT_POOL_MAX_SIZE=50
SESSION_POOL_MAX_SIZE=20

# Monitoring
LOG_LEVEL=INFO
METRICS_PORT=9090

# Graceful shutdown
SHUTDOWN_TIMEOUT=30
